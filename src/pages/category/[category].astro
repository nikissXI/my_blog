---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ArticleCard from '../../components/ArticleCard.astro'
import Pagination from '../../components/Pagination.astro'
import { getCollection, type CollectionEntry } from 'astro:content'
import { PAGE_SIZE, CATEGORIES } from '../../lib/constants'
import { getCategoryName } from '../../lib/utils'

export async function getStaticPaths() {
  const categoryIds = Object.keys(CATEGORIES)
  return categoryIds.map((id) => ({ params: { category: id } }))
}

const { category } = Astro.params
const categoryName = getCategoryName(category, CATEGORIES)

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.category === category)
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const url = new URL(Astro.request.url)
const pageParam = Number(url.searchParams.get('page') || '1')
const currentPage = pageParam > 0 ? pageParam : 1

const totalPages = Math.ceil(sortedPosts.length / PAGE_SIZE)
const safePage = Math.min(currentPage, Math.max(totalPages, 1))
const start = (safePage - 1) * PAGE_SIZE
const pagePosts = sortedPosts.slice(start, start + PAGE_SIZE)

const baseUrl = `/category/${category}`
---

<BaseLayout title={`分类: ${categoryName}`}>
  <div style="margin-bottom: 30px; padding: 10px 15px; background: #f8f9fa; border-radius: 4px;">
    <strong>分类: </strong>
    <span class="category-badge">{categoryName}</span>
    <span style="margin-left: 10px; color: #8b95a5;">共 {sortedPosts.length} 篇文章</span>
    <a href="/" style="float: right; color: #007bff;">&larr; 返回首页</a>
  </div>

  {pagePosts.length === 0 ? (
    <div class="empty-state">
      <p>该分类下暂无文章</p>
    </div>
  ) : (
    pagePosts.map((post) => <ArticleCard post={post} />)
  )}

  <Pagination
    currentPage={safePage}
    totalPages={totalPages}
    baseUrl={baseUrl}
  />
</BaseLayout>
