---
import { CATEGORIES } from "../lib/constants";

const categories = Object.entries(CATEGORIES);
---

<style>
  hr {
    border-color: rgba(255, 255, 255, 0.7);
  }

  .lyear-blogger {
    position: relative;
    z-index: 11;
  }

  .profile-section {
    text-align: center;
  }

  #navigation {
    width: 100%;
  }

  .navbar-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 1rem;
    list-style: none;
    width: 100%;
  }

  .lyear-search-form-container {
    display: flex;
    justify-content: center;
    padding-bottom: 1rem;
  }

  .lyear-search-form .form-control {
    border-radius: 100px;
    background-color: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.125);
    color: rgba(0, 0, 0, 0.7);
    padding: 0.375rem 0.75rem;
    font-size: 14px;
    outline: none;
    max-width: 160px;
  }

  .lyear-search-form .form-control::placeholder {
    color: rgba(0, 0, 0, 0.5);
  }
</style>

<header class="lyear-header" style="background-image:url(/images/left-bg.jpg);">
  <div class="lyear-header-container">
    <div class="lyear-mask"></div>
    <h1 class="lyear-blogger">
      <a href="/">N的小屋</a>
    </h1>
    <nav class="navbar">
      <button
        class="navbar-toggler"
        type="button"
        aria-label="Toggle navigation"
      >
        <div class="lyear-hamburger">
          <div class="hamburger-inner"></div>
        </div>
      </button>

      <div id="navigation">
        <div class="profile-section">
          <img
            class="profile-image"
            src="/images/touxiang.jpg"
            width="120"
            height="120"
            alt="nikiss"
          />
          <div class="lyear-sentence">越努力，越幸运</div>
          <hr />
        </div>

        <ul class="navbar-nav">
          {
            categories.map(([id, name]) => (
              <li>
                <a class="nav-link" href={`/category/${id}`}>
                  {name}
                </a>
              </li>
            ))
          }
          <li>
            <a class="nav-link" href="/about">关于我</a>
          </li>
        </ul>

        <div class="lyear-search-form-container">
          <form class="lyear-search-form">
            <input
              type="text"
              id="keyword"
              name="keyword"
              class="form-control"
              placeholder="搜索关键词"
            />
          </form>
        </div>
      </div>
    </nav>
  </div>
</header>
